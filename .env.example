# ===== AI 配置 =====
# 支持任何 OpenAI 兼容 API（OpenAI / DeepSeek / Groq / Ollama 等）
# 获取密钥：
#   OpenAI:  https://platform.openai.com/api-keys
#   DeepSeek: https://platform.deepseek.com/api_keys
#   Groq:    https://console.groq.com/keys
#   Ollama:  本地运行，无需 Key，baseURL 设为 http://localhost:11434/v1
#
# 当前 demo 无密钥，默认 USE_AI=false 走纯规则主持人（零 token）。
# 拿到密钥后，填入下面两项并把 USE_AI 改为 true 即可启用 AI 增强。
AI_API_KEY=
# API base URL（通常以 /v1 结尾）
AI_BASE_URL=https://api.openai.com/v1
# 模型名称（如 gpt-4o-mini, deepseek-chat, llama-3.3-70b-versatile, qwen2.5 等）
AI_MODEL=gpt-3.5-turbo

# 是否启用 AI 增强：false=纯规则主持人（零 token，无密钥也能跑），true=开启 AI
USE_AI=false

# ===== 服务配置 =====
PORT=3001
# 前端开发服务器地址（用于 CORS，生产由后端托管静态资源无需此配置）
CLIENT_ORIGIN=http://localhost:5173

# ===== 审核台管理口令 =====
ADMIN_PASS=turtle-admin-2026

# 上下文保留最近轮数（约束单次会话 token）
MAX_CONTEXT_ROUNDS=12
